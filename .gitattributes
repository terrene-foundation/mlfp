# Git LFS — track all binary/large files in data/
data/**/*.tar.gz filter=lfs diff=lfs merge=lfs -text
data/**/*.gz filter=lfs diff=lfs merge=lfs -text
data/**/*.parquet filter=lfs diff=lfs merge=lfs -text
data/**/*.arrow filter=lfs diff=lfs merge=lfs -text
data/**/*.pt filter=lfs diff=lfs merge=lfs -text
data/**/*.pkl filter=lfs diff=lfs merge=lfs -text
data/**/*.pickle filter=lfs diff=lfs merge=lfs -text
data/**/*.npy filter=lfs diff=lfs merge=lfs -text
data/**/*.bin filter=lfs diff=lfs merge=lfs -text
data/**/*.pdf filter=lfs diff=lfs merge=lfs -text

# MNIST/CIFAR raw binaries (no extension)
data/**/raw/train-images-* filter=lfs diff=lfs merge=lfs -text
data/**/raw/train-labels-* filter=lfs diff=lfs merge=lfs -text
data/**/raw/t10k-images-* filter=lfs diff=lfs merge=lfs -text
data/**/raw/t10k-labels-* filter=lfs diff=lfs merge=lfs -text

# CIFAR batches (no extension)
data/**/data_batch_* filter=lfs diff=lfs merge=lfs -text
data/**/test_batch filter=lfs diff=lfs merge=lfs -text
data/**/batches.meta filter=lfs diff=lfs merge=lfs -text

# Deck/textbook PDFs in readings/
modules/**/readings/*.pdf filter=lfs diff=lfs merge=lfs -text

# ML model artifacts
.kailash_ml/**/*.pkl filter=lfs diff=lfs merge=lfs -text
