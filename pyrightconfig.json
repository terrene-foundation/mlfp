{
  "include": ["modules", "shared", "scripts"],
  "exclude": [
    "**/__pycache__",
    "**/.ipynb_checkpoints",
    "**/node_modules",
    ".venv",
    "workspaces"
  ],
  "ignore": ["modules/mlfp06/local/**"],
  "venvPath": ".",
  "venv": ".venv",
  "pythonVersion": "3.11",
  "typeCheckingMode": "basic",
  "executionEnvironments": [
    {
      "root": "modules/mlfp06",
      "reportAssignmentType": "none",
      "reportCallIssue": "none",
      "reportArgumentType": "none",
      "reportOptionalMemberAccess": "none"
    },
    {
      "root": "shared/mlfp06",
      "reportAssignmentType": "none",
      "reportCallIssue": "none",
      "reportArgumentType": "none",
      "reportOptionalMemberAccess": "none"
    }
  ]
}
